# Copy this file to .streamlit/secrets.toml for local dev
# OR paste these values into your Streamlit Cloud app's Secrets panel

OPENWEATHER_API_KEY = "your_key_here"   # required — free at openweathermap.org
NREL_API_KEY        = "your_key_here"   # optional — free at developer.nlr.gov
TIMEZONE_API_KEY    = "your_key_here"   # optional — free at timezonedb.com
CESIUM_ION_TOKEN    = "your_token_here" # optional — free at cesium.com/ion
OPENEI_API_KEY      = "your_key_here"   # optional — free at openei.org
