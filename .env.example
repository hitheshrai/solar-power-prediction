# Required
OPENWEATHER_API_KEY=your_key_here   # free at openweathermap.org

# Optional — enables US electricity pricing lookup
NREL_API_KEY=your_key_here          # free at developer.nlr.gov

# Optional — enables accurate local time for solar angle calculation
TIMEZONE_API_KEY=your_key_here      # free at timezonedb.com

# Optional — enables 3D Cesium globe with terrain + buildings
CESIUM_ION_TOKEN=your_token_here    # free at cesium.com/ion

# Optional — enables TOU rate lookup for US utilities
OPENEI_API_KEY=your_key_here        # free at openei.org
